        {
          "name": "CTAPI19 - Validar schema JSON da resposta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Schema esperado (definido manualmente)",
                  "const schema = {",
                  "    \"type\": \"object\",",
                  "    \"required\": [\"bookingid\", \"booking\"],",
                  "    \"properties\": {",
                  "        \"bookingid\": { \"type\": \"integer\" },",
                  "        \"booking\": {",
                  "            \"type\": \"object\",",
                  "            \"required\": [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"],",
                  "            \"properties\": {",
                  "                \"firstname\": { \"type\": \"string\" },",
                  "                \"lastname\": { \"type\": \"string\" },",
                  "                \"totalprice\": { \"type\": \"number\" },",
                  "                \"depositpaid\": { \"type\": \"boolean\" },",
                  "                \"bookingdates\": {",
                  "                    \"type\": \"object\",",
                  "                    \"required\": [\"checkin\", \"checkout\"],",
                  "                    \"properties\": {",
                  "                        \"checkin\": { \"type\": \"string\", \"pattern\": \"^\\\\d{4}-\\\\d{2}-\\\\d{2}$\" },",
                  "                        \"checkout\": { \"type\": \"string\", \"pattern\": \"^\\\\d{4}-\\\\d{2}-\\\\d{2}$\" }",
                  "                    }",
                  "                },",
                  "                \"additionalneeds\": { \"type\": \"string\" }",
                  "            }",
                  "        }",
                  "    }",
                  "};",
                  "",
                  "// Obtém o JSON da resposta",
                  "const response = pm.response.json();",
                  "",
                  "// Valida o schema usando a biblioteca interna 'tv4' (disponível no Postman)",
                  "pm.test(\"Schema da resposta está conforme o esperado\", function () {",
                  "    const tv4 = require('tv4');",
                  "    const result = tv4.validate(response, schema);",
                  "    pm.expect(result).to.be.true;",
                  "    if (!result) {",
                  "        console.log(\"Erro de schema:\", tv4.error);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
