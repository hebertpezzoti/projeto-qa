      "item": [
        {
          "name": "CTAPI18 - Automação via Postman CLI",
          "item": [
            {
              "name": "CTAPI03 - Criar reserva válida",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Pega o JSON da resposta",
                      "var jsonData = pm.response.json();",
                      "",
                      "// Verifica se o campo bookingid existe",
                      "if (jsonData.bookingid) {",
                      "    // Salva o ID em uma variável de COLEÇÃO (disponível para todas as requests da collection)",
                      "    pm.collectionVariables.set(\"bookingId\", jsonData.bookingid);",
                      "    ",
                      "    // Opcional: também salva no environment",
                      "    pm.environment.set(\"bookingId\", jsonData.bookingid);",
                      "    ",
                      "    console.log(\"Booking ID salvo: \" + jsonData.bookingid);",
                      "} else {",
                      "    console.log(\"Erro: bookingid não encontrado na resposta\");",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
